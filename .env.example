# ── OpenAI API ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL_NAME=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Sinyal Kaynakları ─────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key-here

# ── Uygulama ──────────────────────────────────────────────────────────────────
RUNS_DIR=uploads/runs
GRAPH_BACKEND=networkx

# ── E-posta (opsiyonel) ───────────────────────────────────────────────────────
SMTP_PASSWORD=

# ── NOT ───────────────────────────────────────────────────────────────────────
