# ── Groq API (Ana LLM Sağlayıcı) ─────────────────────────────────────────────
# Groq Console: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# Model adı ("groq/" prefix opsiyonel — agents.py otomatik ekler)
LLM_MODEL_NAME=llama-3.3-70b-versatile

# ── OpenAI (Opsiyonel, fallback) ─────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here

# ── Uygulama ──────────────────────────────────────────────────────────────────
RUNS_DIR=uploads/runs

# ── NOT ───────────────────────────────────────────────────────────────────────
# cp .env.example .env
# .env dosyasını asla Git'e commit etme (.gitignore içinde olmalı)
